# Copy file ini menjadi .env lalu isi nilainya.
# JANGAN commit file .env (sudah masuk .gitignore).

# Domain — ganti dengan domain asli sebelum demo
DOMAIN_WEB=demo.example.com
DOMAIN_API=api.demo.example.com

# Password database (generate: openssl rand -hex 16)
POSTGRES_PASSWORD=GANTI_PASSWORD_INI

# Versi app — di CI diisi git SHA pendek; untuk build lokal bebas
VERSION=dev

# Image dari registry (opsional — default ke ghcr.io, override kalau perlu)
# API_IMAGE=ghcr.io/username/demo2-api:latest
# WEB_IMAGE=ghcr.io/username/demo2-web:latest
